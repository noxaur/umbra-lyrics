{
  "name": "umbra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "npm run build:web && npm run build:rust",
    "build:web": "tsc -b && vp build",
    "build:rust": "worker-build --release rust-worker",
    "lint": "vp lint .",
    "preview": "vp preview",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "benchmark:legacy-lyrics": "node scripts/benchmark-legacy-lyrics.mjs",
    "sync:themes": "node scripts/sync-tinted-themes.mjs",
    "test:rust-worker": "npm run build && node scripts/smoke-rust-worker.mjs",
    "test:rust-worker:deployed": "node scripts/smoke-rust-worker-deployed.mjs",
    "deploy": "npm run build && npm run deploy:legacy && npm run deploy:rust",
    "deploy:legacy": "node scripts/deploy-wrangler.mjs dist/song_kara_legacy/wrangler.json",
    "deploy:rust": "node scripts/prepare-wrangler-deploy.mjs wrangler.jsonc dist/rust-worker/wrangler.json && node scripts/deploy-wrangler.mjs dist/rust-worker/wrangler.json",
    "deploy:dry-run": "npm run build && npx wrangler deploy --dry-run --config dist/song_kara_legacy/wrangler.json && node scripts/prepare-wrangler-deploy.mjs wrangler.jsonc dist/rust-worker/wrangler.json && npx wrangler deploy --dry-run --config dist/rust-worker/wrangler.json",
    "fix-dns": "node scripts/fix-dns.mjs",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@bogdanrn/yt-embed": "^0.3.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@huggingface/transformers": "^3.8.1",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "franc-min": "^6.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "onnxruntime-node": "file:vendor/stubs/onnxruntime-node",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "sharp": "file:vendor/stubs/sharp",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "youtubei.js": "^17.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@voidzero-dev/vite-plus-core": "^0.1.24",
    "@voidzero-dev/vite-plus-test": "^0.1.24",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "typescript": "~6.0.2",
    "vite-plus": "^0.1.24",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.24",
    "onnxruntime-node": "file:vendor/stubs/onnxruntime-node",
    "sharp": "file:vendor/stubs/sharp"
  },
  "packageManager": "npm@11.17.0"
}

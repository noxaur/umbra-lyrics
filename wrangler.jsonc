{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "song-kara",
  "main": "worker/index.ts",
  "compatibility_date": "2025-06-15",
  "routes": [
    {
      "pattern": "song.opsec.rent",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
